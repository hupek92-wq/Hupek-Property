# ── 把以下内容复制成 .env 文件，并填入你从 Meta 后台拿到的真实数值 ──

# 在 Meta Developer Portal > WhatsApp > API Setup 取得
WA_PHONE_NUMBER_ID=你的Phone_Number_ID
WA_ACCESS_TOKEN=你的Access_Token
WA_BUSINESS_ACCOUNT_ID=你的WhatsApp_Business_Account_ID

# 自己设置一个验证字符串，Webhook 设置时要填同一个值
WEBHOOK_VERIFY_TOKEN=自己设一个密码字串

# 服务器监听端口（Webhook 接收用）
PORT=3000
